{
  "name": "autodemo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "autodemo": "./bin/autodemo.ts"
  },
  "scripts": {
    "dev": "bun run ./bin/autodemo.ts",
    "format": "prettier --write .",
    "lint": "eslint bin src tests",
    "typecheck": "tsc -p tsconfig.json",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "playwright:install": "bunx playwright install --with-deps",
    "clean:generated": "bun run scripts/cleanGenerated.ts",
    "site:build": "bun run scripts/siteBuild.ts",
    "site:serve": "bun run scripts/siteServe.ts",
    "demos:update": "bun run scripts/updateSiteDemos.ts",
    "doctor": "bun run ./bin/autodemo.ts doctor --no-tui",
    "mcp": "bun run ./bin/autodemo.ts mcp --no-tui",
    "e2e": "bun run test:integration"
  },
  "workspaces": ["tests/integration/fixtures/next-app"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@browserbasehq/stagehand": "^3.0.7",
    "@playwright/test": "^1.57.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^16.4.5",
    "ink": "^6.6.0",
    "openai": "^4.104.0",
    "react": "^19.2.3",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "bun-types": "^1.3.5",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "prettier": "^3.7.4",
    "typescript-eslint": "^8.51.0",
    "typescript": "^5.9.3"
  }
}


